NODE_ENV=development
HOST=0.0.0.0
PORT=4000
CORS_ORIGINS=http://localhost:3000,https://revibe-hub.netlify.app
GROQ_API_KEY=your_groq_api_key_here
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_REPOS_LIMIT=6
FRONTEND_BASE_URL=https://revibe-hub.netlify.app

# Local GitHub OAuth app (used in development/test)
GITHUB_CLIENT_ID_LOCAL=your_local_github_oauth_client_id
GITHUB_CLIENT_SECRET_LOCAL=your_local_github_oauth_client_secret
GITHUB_REDIRECT_URI_LOCAL=http://localhost:4000/api/github/callback

# Deployed GitHub OAuth app (used in production)
GITHUB_CLIENT_ID_PROD=your_prod_github_oauth_client_id
GITHUB_CLIENT_SECRET_PROD=your_prod_github_oauth_client_secret
GITHUB_REDIRECT_URI_PROD=https://your-backend-service.onrender.com/api/github/callback
