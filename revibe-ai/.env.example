# Public backend base URL used by the frontend (no trailing slash).
# Local example:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Production example:
NEXT_PUBLIC_API_BASE_URL=https://your-backend-service.onrender.com

# NextAuth GitHub OAuth
GITHUB_ID=your_github_oauth_client_id
GITHUB_SECRET=your_github_oauth_client_secret
NEXTAUTH_URL=https://revibe-hub.netlify.app
NEXTAUTH_SECRET=generate_a_long_random_secret
